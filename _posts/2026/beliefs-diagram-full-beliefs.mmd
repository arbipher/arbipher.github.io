flowchart TD
    classDef entity fill:#6a9fd8,stroke:#3a6fa0,color:#fff,stroke-width:2px,font-weight:bold
    classDef aux fill:#d8a06a,stroke:#a07a3a,color:#fff,stroke-width:2px,font-weight:bold
    classDef belief fill:#f5f5f5,stroke:#999,color:#666,stroke-width:1px,font-style:italic

    src(["Source code"])
    exp(["Expression"])
    typed_exp(["Typed expression"])
    value(["Value"])
    type(["Type"])
    meta(["Meta-term"])
    code(["Target code"])

    src -->|"parse"| exp
    b0[/"well-formedness"/] -.-o exp
    exp -->|"syntactic
type check"| typed_exp
    b1[/"well-typed"/] -.-o typed_exp
    exp -->|"semantic
type check"| typed_exp
    b2[/"well-typed
(runtime)"/] -.-o typed_exp
    typed_exp -->|"type
inference"| type
    b3[/"principal type"/] -.-o type
    typed_exp -->|"interpret
(big-step)"| value
    b4[/"operational
semantics"/] -.-o value
    typed_exp -->|"interpret
(small-step)"| typed_exp
    b5[/"operational
semantics"/] -.-o typed_exp
    exp -->|"interpret
(untyped)"| value
    b6[/"evaluation"/] -.-o value
    value -->|"REPL
(loop back)"| exp
    b7[/"interaction"/] -.-o exp
    meta -->|"meta-eval"| src
    b8[/"code generation"/] -.-o src
    typed_exp -->|"compile"| code
    b9[/"semantics
preservation"/] -.-o code
    code -->|"decompile
/ unparse"| exp
    b10[/"round-trip"/] -.-o exp

    class src,exp,typed_exp,value entity
    class type,meta,code aux
    class b0,b1,b2,b3,b4,b5,b6,b7,b8,b9,b10 belief
